{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install --prefix backend && npm install --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "framework": "other",
  "env": {
    "PORT": "3000",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "backend/src/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    }
  ]
}
